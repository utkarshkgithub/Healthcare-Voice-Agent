# API Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Feature Flags
VITE_ENABLE_VOICE_RECORDING=false
VITE_ENABLE_ANALYTICS=false

# Voice Provider: webapi (browser-native) | deepgram (server-side, requires VOICE_PROVIDER=deepgram on backend)
VITE_VOICE_PROVIDER=webapi

# App Configuration
VITE_APP_NAME=HealthAI
VITE_APP_VERSION=1.0.0
