# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# ─── Application ─────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
API_HOST=0.0.0.0
API_PORT=8000

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Supported: openai | gemini
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Speech Provider ─────────────────────────────────────────────────────────
# Use 'webapi' for local dev (no API key needed).
# Use 'deepgram' for production-quality STT/TTS.
VOICE_PROVIDER=webapi
DEEPGRAM_API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


# ─── Razorpay Payment ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
